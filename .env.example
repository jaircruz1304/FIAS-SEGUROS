# Opción recomendada: enlace compartido completo del Excel de OneDrive/SharePoint.
FIAS_SEGUROS_EXCEL_URL=https://fiasec-my.sharepoint.com/:x:/g/personal/usuario_fias_org_ec/CODIGO_DEL_ARCHIVO

# Opción alternativa: solo el código share del enlace.
FIAS_SEGUROS_SHARE_ID=CODIGO_DEL_ARCHIVO

# Solo si usas FIAS_SEGUROS_SHARE_ID y tu ruta personal/base no es la siguiente.
FIAS_SHAREPOINT_DOWNLOAD_BASE=https://fiasec-my.sharepoint.com/personal/jcruzg_fias_org_ec/_layouts/15/download.aspx

# Ruta temporal donde el workflow guardará el Excel descargado.
OUTPUT_EXCEL_PATH=tmp/Base_Datos_Seguros_Vehiculares_FIAS.xlsx
