# Copiar este archivo como configuración de referencia. NO guardar secretos reales aquí.

# Microsoft Entra / Azure App Registration
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=NO_ESCRIBIR_AQUI_EN_GITHUB_USAR_SECRET

# OneDrive / SharePoint
# Ejemplo: fiasec.sharepoint.com
OD_SITE_HOST=tu-tenant.sharepoint.com

# Ejemplo: /sites/FONDODEINVERSIONAMBIENTALSOSTENIBLE
OD_SITE_PATH=/sites/NOMBRE_DEL_SITIO

# Normalmente: Documentos
OD_DRIVE_NAME=Documentos

# Ruta del Excel dentro de la biblioteca de documentos
OD_FILE_PATH=Sistemas_FIAS/Seguro_Vehicular/Base_Datos_Seguros_Vehiculares_FIAS.xlsx

# Opcional: ruta local para pruebas
LOCAL_EXCEL_PATH=tmp/Base_Datos_Seguros_Vehiculares_FIAS.xlsx
