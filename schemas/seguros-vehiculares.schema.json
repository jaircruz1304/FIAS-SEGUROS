{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FIAS Seguro Vehicular",
  "type": "object",
  "required": [
    "meta",
    "polizas",
    "bienes",
    "asistencia",
    "procedimiento_siniestro",
    "kpis"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "sistema",
        "ultima_actualizacion"
      ],
      "additionalProperties": true
    },
    "config": {
      "type": "object",
      "additionalProperties": true
    },
    "polizas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id_poliza",
          "poliza_numero",
          "aseguradora",
          "vig_desde",
          "vig_hasta",
          "suma_asegurada_poliza",
          "total_pagado"
        ],
        "properties": {
          "id_poliza": {
            "type": "string",
            "minLength": 1
          },
          "poliza_numero": {
            "type": "string"
          },
          "aseguradora": {
            "type": "string"
          },
          "vig_desde": {
            "type": "string"
          },
          "vig_hasta": {
            "type": "string"
          },
          "suma_asegurada_poliza": {
            "type": "number"
          },
          "total_pagado": {
            "type": "number"
          }
        },
        "additionalProperties": true
      }
    },
    "bienes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id_bien",
          "id_poliza",
          "placa",
          "categoria",
          "marca",
          "modelo",
          "total_asegurado"
        ],
        "properties": {
          "id_bien": {
            "type": "string",
            "minLength": 1
          },
          "id_poliza": {
            "type": "string",
            "minLength": 1
          },
          "placa": {
            "type": "string"
          },
          "categoria": {
            "type": "string"
          },
          "marca": {
            "type": "string"
          },
          "modelo": {
            "type": "string"
          },
          "total_asegurado": {
            "type": "number"
          }
        },
        "additionalProperties": true
      }
    },
    "asistencia": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "procedimiento_siniestro": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "documentos_requeridos": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "faq": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "videos": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "catalogos": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "kpis": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}